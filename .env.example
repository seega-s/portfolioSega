# Configuración de Supabase
# Puedes obtener estas claves en tu panel de Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-clave-anon-publica"

# Clave Service Role (⚠️ NUNCA exponer en el frontend)
# Se utiliza en las API routes (/api/admin/*) para permitir modificaciones en el panel de administración sin RLS
SUPABASE_SERVICE_ROLE_KEY="tu-clave-secreta-service-role"

# URL base de tu sitio web (utilizado para el SEO, Meta tags, sitemaps, etc.)
# Cámbiala por tu dominio real en producción, por ejemplo: https://mi-portfolio.com
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
